-- ── Trait-Daten aus Spiel ─────────────────────────────────────
local TraitData       = nil   -- RS.Shared.Info.Trait (alle normalen Traits)
local DivineTraitData = nil   -- RS.Shared.Info.DivineTraitReRoll (Divine/Mythic Traits)

pcall(function() TraitData       = require(RS.Shared.Info.Trait) end)
pcall(function() DivineTraitData = require(RS.Shared.Info.DivineTraitReRoll) end)

-- Kombiniere alle bekannten Traits
local AllTraits = {}
if TraitData then
    for k,v in pairs(TraitData) do AllTraits[k] = v end
end
if DivineTraitData then
    for k,v in pairs(DivineTraitData) do AllTraits[k] = v end
end

