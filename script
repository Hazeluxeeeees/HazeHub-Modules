H.UI.Fr.WScanBarFill = _wScanBarFill

local _permWorldScanBtn = NeonBtn(_dbToolCard, "🌍  Permanent World Scan (Full Sync)", D.Cyan, 38)

local _worldScanRunning = false

local function RunPermanentWorldScan()
    if _worldScanRunning then
        H.UI.Lbl.DBToolStatus.Text = "⚠ World-Scan läuft bereits!"
        H.UI.Lbl.DBToolStatus.TextColor3 = D.Yellow
        return
    end
    if not S.ScanDone or next(S.WorldData) == nil then
        H.UI.Lbl.DBToolStatus.Text = "⚠ Weltdaten fehlen – zuerst Game-Tab öffnen!"
        H.UI.Lbl.DBToolStatus.TextColor3 = D.Orange
        return
    end

    _worldScanRunning = true
    _permWorldScanBtn.Text = "⏳  Scan läuft..."
    _permWorldScanBtn.TextColor3 = D.Yellow
    _wScanBarBg.Visible = true
    _wScanBarFill.Size = UDim2.new(0, 0, 1, 0)
    _wScanBarFill.BackgroundColor3 = D.Cyan

    task.spawn(function()
        -- Alle Chapters als Tasks sammeln
        local _tasks = {}
        for _, wid in ipairs(S.WorldIds) do
            local wd = S.WorldData[wid] or {}
            local isCal = wid:lower():find("calamity") ~= nil
            for _, cid in ipairs(wd.story or {}) do
                table.insert(_tasks, { worldId = wid, chapId = cid,
                    mode = isCal and "Calamity" or "Story" })
            end
            for _, cid in ipairs(wd.ranger or {}) do
                table.insert(_tasks, { worldId = wid, chapId = cid, mode = "Ranger" })
            end
        end

        local _total  = #_tasks
        local _done   = 0
        local _failed = 0

        if _total == 0 then
            H.UI.Lbl.DBToolStatus.Text = "⚠ Keine Chapters gefunden!"
            H.UI.Lbl.DBToolStatus.TextColor3 = D.Orange
            _worldScanRunning = false
            _permWorldScanBtn.Text = "🌍  Permanent World Scan (Full Sync)"
            _permWorldScanBtn.TextColor3 = D.Cyan
            return
        end

        print(string.format("[HazeHUB] Permanent World Scan: %d Chapters", _total))

        -- PlayRoom-Remote holen (gleiche Logik wie R.PlayRoom oben)
        local _prRemote = nil
        pcall(function()
            _prRemote = Svc.RS:WaitForChild("Remote", 5)
                :WaitForChild("Server", 5)
                :WaitForChild("PlayRoom", 5)
                :WaitForChild("Event", 5)
        end)

        local function _Fire(action, data)
            if _prRemote then
                pcall(function()
                    if data then _prRemote:FireServer(action, data)
                    else         _prRemote:FireServer(action) end
                end)
            else
                -- Fallback auf das globale PR aus dem Hauptskript
                PR(action, data)
            end
        end

        _Fire("Create"); task.wait(1.5)

        for _, t in ipairs(_tasks) do
            _done = _done + 1
            local _pct  = _done / _total
            local _prog = string.format("🌍 %d/%d  [%s] %s",
                _done, _total, t.mode, t.chapId)

            pcall(function()
                H.UI.Lbl.WScanProgress.Text = _prog
                H.UI.Lbl.DBToolStatus.Text  = _prog
                H.UI.Lbl.DBToolStatus.TextColor3 = D.Yellow
                Tw(_wScanBarFill, { Size = UDim2.new(_pct, 0, 1, 0) }, TF)
            end)

            print(string.format("[HazeHUB] WorldScan [%s] %s → %s (%d/%d)",
                t.mode, t.worldId, t.chapId, _done, _total))

            local _ok = pcall(function()
                if t.mode == "Story" then
                    _Fire("Create");                                          task.wait(0.4)
                    _Fire("Change-World",   { World   = t.worldId });        task.wait(0.4)
                    _Fire("Change-Chapter", { Chapter = t.chapId })
                elseif t.mode == "Ranger" then
                    _Fire("Create");                                          task.wait(0.4)
                    _Fire("Change-Mode",
                        { KeepWorld = t.worldId, Mode = "Ranger Stage" });   task.wait(0.6)
                    _Fire("Change-World",   { World   = t.worldId });        task.wait(0.4)
                    _Fire("Change-Chapter", { Chapter = t.chapId })
                elseif t.mode == "Calamity" then
                    _Fire("Create");                                          task.wait(0.4)
                    _Fire("Change-Mode",    { Mode    = "Calamity" });       task.wait(0.4)
                    _Fire("Change-Chapter", { Chapter = t.chapId })
                end
            end)

            if not _ok then _failed = _failed + 1 end

            -- ★ 2 Sekunden Pflicht-Aufenthalt pro Stage
            task.wait(2.0)

            -- Stage schließen, bereit für nächste
            pcall(function()
                _Fire("Submit"); task.wait(0.3)
                _Fire("Create"); task.wait(0.5)
            end)
        end

        -- ★ WorldCache speichern – nutzt SaveWorldData() aus dem Hauptskript
        pcall(SaveWorldData)

        local _msg = string.format(
            "✅ World Scan fertig! %d/%d Chapters gespeichert (%d Fehler)",
            _done - _failed, _total, _failed)
        print("[HazeHUB] " .. _msg)

        pcall(function()
            H.UI.Lbl.WScanProgress.Text = _msg
            H.UI.Lbl.DBToolStatus.Text  = _msg
            H.UI.Lbl.DBToolStatus.TextColor3 = D.Green
            Tw(_wScanBarFill,
                { Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = D.Green }, TM)
            _permWorldScanBtn.Text = "🌍  Permanent World Scan (Full Sync)"
            _permWorldScanBtn.TextColor3 = D.Cyan
            H.UI.Lbl.ScanStatus.Text =
                "✅ " .. #S.WorldIds .. " Welten (Permanent Cache)"
            H.UI.Lbl.ScanStatus.TextColor3 = D.Green
        end)

        _worldScanRunning = false
    end)
end

_permWorldScanBtn.MouseButton1Click:Connect(RunPermanentWorldScan)

-- Auch über _G.HazeShared aufrufbar (z. B. aus autofarm)
_G.HazeShared.RunPermanentWorldScan = RunPermanentWorldScan

