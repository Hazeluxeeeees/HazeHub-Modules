-- ╔══════════════════════════════════════════════════════════╗
--  BUTTON 1 – Reset & Rescan Rewards
-- ╚══════════════════════════════════════════════════════════╝
MkLbl(_dbToolCard,
    "Löscht HazeHUB_RewardDB.json und startet sofort den Deep-Scan neu.",
    9, D.TextLow
).Size = UDim2.new(1, 0, 0, 22)

local _resetRescanBtn = NeonBtn(_dbToolCard, "🔄  Reset & Rescan Rewards", D.Red, 38)

_resetRescanBtn.MouseButton1Click:Connect(function()
    if _resetRescanBtn.Text:find("läuft") then return end

    -- 1. RewardDB-Datei löschen
    local _dbFile = "HazeHUB/HazeHUB_RewardDB.json"
    pcall(function()
        if isfile and isfile(_dbFile) then
            delfile(_dbFile)
            print("[HazeHUB] RewardDB.json gelöscht.")
        end
    end)

    -- 2. Autofarm-Modul über _G.HazeShared ansprechen
    if _G.HazeShared and _G.HazeShared.TriggerResetRescan then
        _resetRescanBtn.Text = "⏳  Scan läuft..."
        _resetRescanBtn.TextColor3 = D.Yellow
        H.UI.Lbl.DBToolStatus.Text = "⏳ RewardDB gelöscht – Deep-Scan gestartet..."
        H.UI.Lbl.DBToolStatus.TextColor3 = D.Yellow

        task.spawn(function()
            _G.HazeShared.TriggerResetRescan(function(msg)
                pcall(function()
                    H.UI.Lbl.DBToolStatus.Text = msg
                    H.UI.Lbl.DBToolStatus.TextColor3 = D.Green
                end)
            end)
            task.wait(1)
            pcall(function()
                _resetRescanBtn.Text = "🔄  Reset & Rescan Rewards"
                _resetRescanBtn.TextColor3 = D.Red
            end)
        end)
    else
        H.UI.Lbl.DBToolStatus.Text = "⚠ Autofarm-Modul nicht geladen – bitte warten!"
        H.UI.Lbl.DBToolStatus.TextColor3 = D.Orange
    end
end)

