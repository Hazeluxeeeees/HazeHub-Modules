_sepCWC.Size = UDim2.new(1, 0, 0, 1)
_sepCWC.BackgroundColor3 = D.Border
_sepCWC.BackgroundTransparency = 0.4
_sepCWC.BorderSizePixel = 0

MkLbl(_dbToolCard,
    "Löscht HazeHUB_WorldCache.json und setzt die Weltliste auf Standard zurück.",
    9, D.TextLow
).Size = UDim2.new(1, 0, 0, 22)

local _clearCacheBtn = NeonBtn(_dbToolCard, "🗑  Clear World Cache", D.Orange, 34)

_clearCacheBtn.MouseButton1Click:Connect(function()
    -- 1. Cache-Datei löschen
    pcall(function()
        if isfile and isfile(WORLD_CACHE_FILE) then
            delfile(WORLD_CACHE_FILE)
            print("[HazeHUB] WorldCache.json gelöscht.")
        end
    end)

    -- 2. Laufzeit-State zurücksetzen
    S.WorldData     = {}
    S.WorldIds      = {}
    S.ScanDone      = false
    S.ChapFolderRef = nil
    S.SelWorld      = nil
    S.SelChap       = nil

    -- 3. Welt-Buttons im Game-Tab leeren
    pcall(function()
        for _, v in pairs(H.UI.Fr.WorldBtns:GetChildren()) do
            if v:IsA("TextButton") then v:Destroy() end
        end
        for _, v in pairs(H.UI.Fr.ChapRow:GetChildren()) do
            if v:IsA("TextButton") then v:Destroy() end
        end
        H.UI.Fr.ChapBtns = {}
    end)

    -- 4. Status-Labels aktualisieren
    pcall(function()
        H.UI.Lbl.WorldStatus.Text =
            "🗑 Cache gelöscht – Game-Tab öffnen für Neu-Scan"
        H.UI.Lbl.WorldStatus.TextColor3 = D.Orange
        H.UI.Lbl.ScanStatus.Text =
            "⚠ Kein Cache – beim nächsten Start wird neu gescannt"
        H.UI.Lbl.ScanStatus.TextColor3 = D.Orange
        H.UI.Lbl.DBToolStatus.Text =
            "✅ WorldCache.json gelöscht. Nächster Start scannt neu."
        H.UI.Lbl.DBToolStatus.TextColor3 = D.Green
    end)

    -- 5. Fallback laden damit GUI nicht leer bleibt
    ApplyFallback()
    pcall(RebuildWorldList)

    print("[HazeHUB] World-Cache geleert. Nächster Start erzwingt frischen Scan.")
end)
