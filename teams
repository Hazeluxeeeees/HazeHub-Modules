-- ── Hilfsfunktion: Gear-Table für Anzeige ─────────────────────
-- Gibt einen kompakten String zurück, z. B. "H✓ B— A✓ L— S✓"
local function FormatGearPreview(gear)
    if not gear then return "—" end
    local slots = {
        { key="HeadGear", short="H" },
        { key="BodyGear",  short="B" },
        { key="ArmsGear",  short="A" },
        { key="LegsGear",  short="L" },
        { key="Soul",      short="S" },
    }
    local parts = {}
    local count = 0
    for _, s in ipairs(slots) do
        local v = gear[s.key]
        if v and v ~= "" then
            table.insert(parts, s.short .. "✓")
            count = count + 1
        else
            table.insert(parts, s.short .. "—")
        end
    end
    return table.concat(parts, " ") .. "  [" .. count .. "/5]"
end

-- ── Backward-Compat: Slot-Eintrag normalisieren ───────────────
-- Alte Saves: slots[i] = "UnitName" (string)
-- Neue Saves: slots[i] = { name="...", tag="..." }
local function NormalizeSlot(v)
    if type(v) == "string" then
        return { name = v, tag = "" }
    elseif type(v) == "table" then
        return v
    end
    return nil
end

-- ══════════════════════════════════════════════════════════════
--  5-STUFEN LOAD-WORKFLOW
-- ══════════════════════════════════════════════════════════════
local function LoadTeam(team, feedbackFn)
    local function Status(txt, col)
        print("[HazeHub/Teams] " .. txt)
        if feedbackFn then pcall(feedbackFn, txt, col) end
    end

    -- ── SCHRITT 1: Full Equipment Strip ───────────────────────
    -- Alle aktuell ausgerüsteten Einheiten identifizieren und
    -- komplett von Equipment befreien BEVOR UnEquipAll gefeuert wird
    Status("⏳ [1/5] Full Equipment Strip...", D.Yellow)

    local currentSlots, _, _ = ScanCurrentLoadout()
    for i = 1, 6 do
        local slotData = currentSlots[i]
        if slotData then
            local unitName = type(slotData) == "table" and slotData.name or slotData
            local u = FindUnitInCollection(unitName)
            if u then
                Status("  Strip Slot " .. i .. ": " .. u.name, D.TextMid)
                StripAllGearFromUnit(u.instance)
            end
        end
    end
    task.wait(WAIT_STRIP_DONE)

    -- ── SCHRITT 2: Unit Unequip (alle Slots leeren) ────────────
    Status("⏳ [2/5] UnEquip alle Units...", D.Yellow)
    FireUnEquipAll()
    task.wait(WAIT_AFTER_UNIT)

    -- ── SCHRITT 3 + 4: Pro Slot – Unit & Gear Swap ────────────
    Status("⏳ [3/5] Unit & Gear Swap...", D.Yellow)

    for i = 1, 6 do
        local rawSlot = team.slots and team.slots[i]
        if not rawSlot then
            print("[HazeHub/Teams]   Slot " .. i .. " → leer, übersprungen.")
        else
            local slotData = NormalizeSlot(rawSlot)
            -- Einheit per Tag finden (primär), Name als Fallback
            local lookupKey = (slotData.tag and slotData.tag ~= "") and slotData.tag or slotData.name
            local u = FindUnitInCollection(lookupKey)

            if not u then
                warn("[HazeHub/Teams]   Slot " .. i .. ": Unit '" .. tostring(lookupKey) .. "' nicht in Collection!")
            else
                Status("  [" .. i .. "/6] Equip: " .. u.name .. " [" .. u.tag .. "]", D.Cyan)

                -- 3a) Unit in Slot equippen
                local ok = FireEquip(u.instance)
                if not ok then
                    warn("[HazeHub/Teams]   Slot " .. i .. " Equip fehlgeschlagen!")
                    task.wait(WAIT_EQUIP_DONE)
                else
                    task.wait(WAIT_EQUIP_DONE)

                    -- 3b) Unit-Equipment entfernen (frischer Stand vor Equip)
                    -- Frische Instanz aus Collection holen (nach Equip ggf. stale)
                    local freshU = FindUnitInCollection(u.tag ~= "" and u.tag or u.name)
                    local targetFolder = (freshU and freshU.instance) or u.instance
                    StripAllGearFromUnit(targetFolder)
                    task.wait(WAIT_AFTER_UNIT)

                    -- 3c) Gespeichertes Equipment laden
                    local gear = nil
                    if team.equipment then
                        -- Primär per Tag suchen
                        if slotData.tag and slotData.tag ~= "" then
                            gear = team.equipment[slotData.tag]
                        end
                        -- Fallback: per Name iterieren
                        if not gear and slotData.name then
                            for tag, g in pairs(team.equipment) do
                                _ = tag -- suppress unused
                                gear = g; break
                            end
                        end
                    end

                    if gear then
                        Status("    Gear Equip für " .. u.name .. " → " .. FormatGearPreview(gear), D.Teal)

                        -- Reihenfolge: HeadGear → BodyGear → ArmsGear → LegsGear → Soul
                        for _, slotName in ipairs(GEAR_SLOTS) do
                            local itemName = gear[slotName]
                            if itemName and itemName ~= "" then
                                FireGearEquip(targetFolder, itemName)
                            end
                        end
                        -- Soul
                        local soulName = gear.Soul
                        if soulName and soulName ~= "" then
                            FireSoulEquip(targetFolder, soulName)
                        end
                    else
                        Status("    Keine gespeicherten Gears für " .. u.name, D.TextLow)
                    end

                    task.wait(0.2)
                end
            end
        end
    end

    -- ── SCHRITT 5: AutoUpgrade aktivieren ─────────────────────
    Status("⏳ [5/5] AutoUpgrade-Konfiguration...", D.Yellow)
    if team.autoUpgrade then
        for i = 1, 6 do
            local v = team.autoUpgrade[i]
            if v ~= nil then
                FireAutoUpgrade(i, v)
                task.wait(0.15)
            end
        end
    end

    Status("✅ Team '" .. (team.name or "?") .. "' vollständig geladen!", D.GreenBright)
end

