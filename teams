        saveFeedback.Text       = "⚠ Bitte einen Team-Namen eingeben!"
        saveFeedback.TextColor3 = D.Orange
        return
    end

    -- Neuester Scan verwenden (oder frisch scannen wenn leer)
    local slots, autoUp, equipment = _lastScannedSlots, _lastScannedAutoUp, _lastScannedEquipment
    local hasData = false
    for i = 1, 6 do if slots[i] then hasData = true; break end end
    if not hasData then
        saveFeedback.Text       = "⚠ Kein Loadout gefunden. Bitte erst scannen."
        saveFeedback.TextColor3 = D.Orange
        return
    end

    -- Equipment-Statistiken
    local unitCount  = 0
    local gearTotal  = 0
    for i = 1, 6 do
        if slots[i] then
            unitCount = unitCount + 1
            local tag  = slots[i].tag
            local gear = tag ~= "" and equipment[tag] or nil
            if gear then
                for _, sn in ipairs(GEAR_SLOTS) do
                    if gear[sn] and gear[sn] ~= "" then gearTotal = gearTotal + 1 end
                end
                if gear.Soul and gear.Soul ~= "" then gearTotal = gearTotal + 1 end
            end
        end
    end

    local existIdx = nil
    for i, t in ipairs(TM_State.Teams) do
        if t.name == teamName then existIdx = i; break end
    end

    local entry = {
        name        = teamName,
        slots       = slots,        -- { [i] = {name, tag} }
        autoUpgrade = autoUp,
        equipment   = equipment,    -- { [tag] = {HeadGear, BodyGear, ...} }
        savedAt     = os.time(),
        unitCount   = unitCount,
        gearCount   = gearTotal,
    }

    if existIdx then
        TM_State.Teams[existIdx] = entry
        saveFeedback.Text = string.format(
            "✅ '%s' überschrieben! (%d/6 Units · %d Gear-Slots)", teamName, unitCount, gearTotal)
    else
        table.insert(TM_State.Teams, entry)
        saveFeedback.Text = string.format(
            "✅ '%s' gespeichert! (%d/6 Units · %d Gear-Slots)", teamName, unitCount, gearTotal)
    end
    saveFeedback.TextColor3 = D.GreenBright
    nameBox.Text = ""
    SaveTeamsFile()
    task.delay(6, function() pcall(function() if saveFeedback then saveFeedback.Text = "" end end) end)
    pcall(_G._RebuildTeamsList)
end)

