-- ── Aktuelles Loadout + Equipment scannen ─────────────────────
-- Gibt zurück:
--   slots[i]     = { name=string, tag=string } oder nil
--   autoUpgrade  = { [i] = value }
--   equipment    = { [tag] = {HeadGear, BodyGear, ArmsGear, LegsGear, Soul} }
local function ScanCurrentLoadout()
    local slots     = {}
    local autoUp    = {}
    local equipment = {}

    pcall(function()
        local pd   = RS:WaitForChild("Player_Data", 5):WaitForChild(LP.Name, 5)
        local data = pd:WaitForChild("Data", 5)

        -- Hole Collection einmalig für Gear-Scan
        local col = nil
        pcall(function()
            col = pd:WaitForChild("Collection", 5)
        end)

        for i = 1, 6 do
            local lv = data:FindFirstChild("UnitLoadout" .. i)
            if lv then
                local v = tostring(lv.Value)
                if v ~= "" and v ~= "nil" then
                    -- Unit-Name aus Loadout → Tag + Gear aus Collection
                    local unitFolder = col and col:FindFirstChild(v)
                    local tag = ""
                    local gear = { HeadGear="", BodyGear="", ArmsGear="", LegsGear="", Soul="" }

                    if unitFolder then
                        local tagObj = unitFolder:FindFirstChild("Tag")
                        tag = tagObj and tostring(tagObj.Value) or ""

                        -- Equipment-Scan: jede Value im Folder
                        for _, slotName in ipairs(GEAR_SLOTS) do
                            local gObj = unitFolder:FindFirstChild(slotName)
                            gear[slotName] = gObj and tostring(gObj.Value) or ""
                        end
                        local soulObj = unitFolder:FindFirstChild("Soul")
                        gear.Soul = soulObj and tostring(soulObj.Value) or ""
                    end

                    slots[i] = { name = v, tag = tag }

                    -- Equipment pro Tag ablegen (nur wenn Tag vorhanden)
                    if tag ~= "" then
                        equipment[tag] = gear
                    end
                end
            end
        end

        -- AutoUpgradeConfig
        local auConf = pd:FindFirstChild("AutoUpgradeConfig")
        if auConf then
            for i = 1, 6 do
                local auSlot = auConf:FindFirstChild(tostring(i))
                if auSlot then autoUp[i] = auSlot.Value end
            end
        end
    end)

    return slots, autoUp, equipment
end

