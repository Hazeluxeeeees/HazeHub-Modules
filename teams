-- ── Remote-Helfer ─────────────────────────────────────────────
-- Cached Remote-Instanzen für den Load-Prozess
local function GetRemote(...)
    local node = RS
    for _, name in ipairs({...}) do
        node = node:WaitForChild(name, 10)
        if not node then
            warn("[HazeHub/Teams] Remote-Pfad nicht gefunden: " .. name)
            return nil
        end
    end
    return node
end

-- ★ Unit Equip: Instance aus Collection übergeben
local function FireEquip(unitInstance)
    local ok, err = pcall(function()
        GetRemote("Remote","Server","Units","Equip"):FireServer(unitInstance)
    end)
    if not ok then warn("[HazeHub/Teams] Units.Equip Fehler: " .. tostring(err)) end
    return ok
end

-- ★ UnEquipAll: leert alle 6 Slots serverseitig
local function FireUnEquipAll()
