        else
            p.nameLbl.Text       = "—  (leer)"
            p.nameLbl.TextColor3 = D.TextLow
            p.gearLbl.Text       = ""
        end
    end
    SetTMStatus("✅ Loadout + Equipment gescannt!", D.Green)
end

