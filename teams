-- ── Strip-Helper: entfernt das gesamte Equipment einer Einheit ─
-- Feuert Unequip für alle 4 Gear-Slots + Soul
local function StripAllGearFromUnit(unitFolder)
    if not unitFolder then return end
    for _, slot in ipairs(GEAR_SLOTS) do
        FireGearUnequip(unitFolder, slot)
    end
    FireSoulUnequip(unitFolder)
end

-- ── Collection-Mapper ──────────────────────────────────────────
-- Gibt ALLE Einheiten aus Player_Data.[LP.Name].Collection zurück
-- Ergebnis: { {name, tag, instance, gear={...}} }
local function GetAllUnitsFromCollection()
    local result = {}
    local col = nil
    pcall(function()
        col = RS:WaitForChild("Player_Data", 5)
                :WaitForChild(LP.Name, 5)
                :WaitForChild("Collection", 5)
    end)
    if not col then return result end

    for _, unitFolder in ipairs(col:GetChildren()) do
        if unitFolder:IsA("Folder") then
            local tagObj = unitFolder:FindFirstChild("Tag")
            local tagVal = tagObj and tostring(tagObj.Value) or ""

            -- Equipment aus Collection lesen
            local gear = {}
            for _, slotName in ipairs(GEAR_SLOTS) do
                local gObj = unitFolder:FindFirstChild(slotName)
                gear[slotName] = gObj and tostring(gObj.Value) or ""
            end
            local soulObj = unitFolder:FindFirstChild("Soul")
            gear.Soul = soulObj and tostring(soulObj.Value) or ""

            table.insert(result, {
                name     = unitFolder.Name,
                tag      = tagVal,
                instance = unitFolder,
                gear     = gear,
            })
        end
    end
    return result
end

-- Sucht eine Einheit in der Collection per Tag (primär) oder Name (Fallback)
-- Gibt { name, tag, instance, gear } zurück oder nil
local function FindUnitInCollection(tagOrName)
    if not tagOrName or tagOrName == "" then return nil end
    local units = GetAllUnitsFromCollection()
    -- 1. Exakter Tag
    for _, u in ipairs(units) do
        if u.tag == tagOrName then return u end
    end
    -- 2. Exakter Name
    for _, u in ipairs(units) do
        if u.name == tagOrName then return u end
    end
    -- 3. Name case-insensitiv
    local low = tagOrName:lower()
    for _, u in ipairs(units) do
        if u.name:lower() == low then return u end
    end
    return nil
end

