local function BuildPityBar(parent, label, color)
    color = color or D.Purple
    local row = Instance.new("Frame",parent)
    row.Size=UDim2.new(1,0,0,42); row.BackgroundColor3=D.CardHover
    row.BorderSizePixel=0; Corner(row,7); Stroke(row,color,1,0.5)
    local acBar = Instance.new("Frame",row)
    acBar.Size=UDim2.new(0,3,1,0); acBar.BackgroundColor3=color; acBar.BorderSizePixel=0; Corner(acBar,2)
    -- Name
    local nameLbl = Instance.new("TextLabel",row)
    nameLbl.Position=UDim2.new(0,10,0,4); nameLbl.Size=UDim2.new(0.6,-10,0,14)
    nameLbl.BackgroundTransparency=1; nameLbl.Text=label; nameLbl.TextColor3=color
    nameLbl.TextSize=11; nameLbl.Font=Enum.Font.GothamBold; nameLbl.TextXAlignment=Enum.TextXAlignment.Left
    -- Wert
    local valLbl = Instance.new("TextLabel",row)
    valLbl.Position=UDim2.new(0.6,0,0,4); valLbl.Size=UDim2.new(0.39,-6,0,14)
    valLbl.BackgroundTransparency=1; valLbl.Text="0 / –"; valLbl.TextColor3=D.TextHi
    valLbl.TextSize=11; valLbl.Font=Enum.Font.GothamBold; valLbl.TextXAlignment=Enum.TextXAlignment.Right
    -- Balken-Hintergrund
    local barBg = Instance.new("Frame",row)
    barBg.Position=UDim2.new(0,10,0,24); barBg.Size=UDim2.new(1,-16,0,10)
    barBg.BackgroundColor3=Color3.fromRGB(20,15,40); barBg.BorderSizePixel=0; Corner(barBg,5)
    -- Balken-Füllung
    local barFill = Instance.new("Frame",barBg)
    barFill.Size=UDim2.new(0,0,1,0); barFill.BackgroundColor3=color; barFill.BorderSizePixel=0; Corner(barFill,5)
    local grad = Instance.new("UIGradient",barFill)
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, color),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(
            math.min(255, math.floor(color.R*255*1.5)),
            math.min(255, math.floor(color.G*255*1.5)),
            math.min(255, math.floor(color.B*255*1.5))
        )),
    })
    return valLbl, barFill
end

