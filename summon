-- ══ Helpers ══
local function ReadPath(...)
    local val=0; pcall(function()
        local n=RS:WaitForChild("Player_Data",3):WaitForChild(LP.Name,3)
        for _,p in ipairs({...}) do n=n:WaitForChild(p,2) end
        val=tonumber(n.Value) or 0
    end); return val
end
local function GetAutoSells()
    local t={}; for _,r in ipairs(RARITIES) do if autoSell[r] then t[r]=true end end; return t
end
local function BypassClick()
    task.spawn(function()
        for _=1,15 do task.wait(0.4)
            local done=false
            pcall(function()
                for _,d in ipairs(LP:WaitForChild("PlayerGui",2):GetDescendants()) do
                    local n=d.Name:lower()
                    if (d:IsA("TextButton") or d:IsA("ImageButton")) and (n:find("click") or n:find("anywhere") or n:find("continue")) then
                        pcall(function() d.Parent.Visible=false end); done=true
                    end
                end
            end)
            if done then break end
        end
    end)
end

