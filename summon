    local nL=Instance.new("TextLabel",row); nL.Position=UDim2.new(0,10,0,4); nL.Size=UDim2.new(0.6,-10,0,14)
    nL.BackgroundTransparency=1; nL.Text=lbl; nL.TextColor3=col; nL.TextSize=11; nL.Font=Enum.Font.GothamBold
    nL.TextXAlignment=Enum.TextXAlignment.Left; nL.TextScaled=false; nL.RichText=true; nL.TextStrokeTransparency=1
    local vL=Instance.new("TextLabel",row); vL.Position=UDim2.new(0.6,0,0,4); vL.Size=UDim2.new(0.39,-6,0,14)
    vL.BackgroundTransparency=1; vL.Text="0 / –"; vL.TextColor3=C.Hi; vL.TextSize=11; vL.Font=Enum.Font.GothamBold
    vL.TextXAlignment=Enum.TextXAlignment.Right; vL.TextScaled=false; vL.RichText=true; vL.TextStrokeTransparency=1
    local bg=Instance.new("Frame",row); bg.Position=UDim2.new(0,10,0,26); bg.Size=UDim2.new(1,-16,0,10)
    bg.BackgroundColor3=Color3.fromRGB(18,12,35); bg.BorderSizePixel=0; Corner(bg,5)
    local fill=Instance.new("Frame",bg); fill.Size=UDim2.new(0,0,1,0); fill.BackgroundColor3=col; fill.BorderSizePixel=0; Corner(fill,5)
    return vL,fill
end
local solSec=Instance.new("Frame",pityCard); solSec.Size=UDim2.new(1,0,0,0); solSec.AutomaticSize=Enum.AutomaticSize.Y; solSec.BackgroundTransparency=1; VList(solSec,5)
for _,pp in ipairs(SOL_P) do
    local vL,fill=MkPBar(solSec,"☀️  "..pp.lbl,pp.col); pUI[pp.key]={lbl=vL,fill=fill,max=pp.max}
end
local stdSec=Instance.new("Frame",pityCard); stdSec.Size=UDim2.new(1,0,0,0); stdSec.AutomaticSize=Enum.AutomaticSize.Y; stdSec.BackgroundTransparency=1; VList(stdSec,5)
do local vL,fill=MkPBar(stdSec,"🎴  Banner Pity",C.Cyan); pUI["BannerPity"]={lbl=vL,fill=fill,max=3500} end
local function RefreshPity()
    for _,pp in ipairs(SOL_P) do
        local e=pUI[pp.key]; if not e then continue end
        pcall(function()
            local v=ReadPath("Profile",pp.key); local p=math.max(0,math.min(1,v/math.max(1,e.max)))
            e.lbl.Text=v.." / "..e.max; Tw(e.fill,{Size=UDim2.new(p,0,1,0)})
        end)
    end
    pcall(function()
        local e=pUI["BannerPity"]; if not e then return end
        local v=ReadPath("BannerPity","Pity"); local p=math.max(0,math.min(1,v/math.max(1,e.max)))
        e.lbl.Text=v.." / "..e.max; Tw(e.fill,{Size=UDim2.new(p,0,1,0)})
    end)
end
NeonBtn(pityCard,"🔄  Pity aktualisieren",C.CyanD,28).MouseButton1Click:Connect(function() task.spawn(function() pcall(RefreshPity) end) end)

