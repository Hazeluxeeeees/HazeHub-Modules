-- Pity aktualisieren
local function RefreshPity()
    for _, pp in ipairs(SOL_PITY_PATHS) do
        local e = pityUI[pp.key]; if not e then continue end
        pcall(function()
            local val = ReadPlayerPath("Profile", pp.key) or 0
            local pct = math.max(0, math.min(1, val/math.max(1,e.max)))
            e.lbl.Text = tostring(val).." / "..tostring(e.max)
            Tw(e.fill, {Size=UDim2.new(pct,0,1,0)})
        end)
    end
    pcall(function()
        local e = pityUI["BannerPity"]; if not e then return end
        local val = ReadPlayerPath("BannerPity","Pity") or 0
        local pct = math.max(0, math.min(1, val/math.max(1,e.max)))
        e.lbl.Text = tostring(val).." / "..tostring(e.max)
        Tw(e.fill, {Size=UDim2.new(pct,0,1,0)})
    end)
end

NeonBtn(pityCard,"🔄  Pity aktualisieren",D.CyanDim,28).MouseButton1Click:Connect(function()
