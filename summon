local HS = _G.HazeShared
local D  = HS.D or {}
local function DC(k,r,g,b) return D[k] or Color3.fromRGB(r,g,b) end
local C = {
    Card=DC("Card",15,15,18), Hover=DC("CardHover",22,22,28),
    Input=DC("Input",20,20,25), Border=DC("Border",50,50,65),
    GP=D.GlassPane or 0.18,
    Purple=DC("Purple",120,40,220), Cyan=DC("Cyan",0,200,240),
    CyanD=DC("CyanDim",0,120,160), Gold=DC("Gold",255,195,0),
    Red=DC("Red",220,50,60), Green=DC("Green",0,200,100),
    GreenB=DC("GreenBright",80,255,140), Yellow=DC("Yellow",255,215,0),
    Hi=DC("TextHi",240,240,248), Mid=DC("TextMid",170,170,185),
    Low=DC("TextLow",90,90,110),
}
local Tw = HS.Tw or function() end
-- UI helpers – eigene Impl. wenn HS-Version fehlt
local function Corner(f,r) pcall(function() local c=Instance.new("UICorner",f); c.CornerRadius=UDim.new(0,r or 8) end) end
local function Stroke(f,col,t,tr) pcall(function() local s=Instance.new("UIStroke",f); s.Color=col; s.Thickness=t or 1; s.Transparency=tr or 0 end) end
local function Pad(p,a,b,c2,d) pcall(function() local u=Instance.new("UIPadding",p); u.PaddingTop=UDim.new(0,a or 6); u.PaddingRight=UDim.new(0,b or 6); u.PaddingBottom=UDim.new(0,c2 or 6); u.PaddingLeft=UDim.new(0,d or 6) end) end
local function VList(p,g) local l=Instance.new("UIListLayout",p); l.FillDirection=Enum.FillDirection.Vertical; l.Padding=UDim.new(0,g or 6); l.SortOrder=Enum.SortOrder.LayoutOrder; return l end
local function HList(p,g) local l=Instance.new("UIListLayout",p); l.FillDirection=Enum.FillDirection.Horizontal; l.VerticalAlignment=Enum.VerticalAlignment.Center; l.Padding=UDim.new(0,g or 6); l.SortOrder=Enum.SortOrder.LayoutOrder; return l end
local function Lbl(parent,text,size,col,bold)
    local l=Instance.new("TextLabel",parent); l.BackgroundTransparency=1; l.Text=text or ""
    l.TextSize=size or 12; l.TextColor3=col or C.Hi; l.Font=bold and Enum.Font.GothamBold or Enum.Font.GothamMedium
    l.TextXAlignment=Enum.TextXAlignment.Left; l.TextWrapped=true
    l.TextScaled=false; l.RichText=true; l.TextStrokeTransparency=1
    l.Size=UDim2.new(1,0,0,(size or 12)+8); return l
end
local function SecLbl(p,t) local l=Lbl(p,t,10,C.Low); l.Size=UDim2.new(1,0,0,16); return l end
local function Card(parent,h)
    local f=Instance.new("Frame",parent); f.BackgroundColor3=C.Card; f.BackgroundTransparency=C.GP; f.BorderSizePixel=0
    if h then f.Size=UDim2.new(1,0,0,h) else f.Size=UDim2.new(1,0,0,0); f.AutomaticSize=Enum.AutomaticSize.Y end
    Corner(f,8); Stroke(f,C.Border,1,0.55); return f
end
local function NeonBtn(parent,text,acc,h)
    local b=Instance.new("TextButton",parent); b.Size=UDim2.new(1,0,0,h or 34)
    b.BackgroundColor3=C.Hover; b.BackgroundTransparency=C.GP; b.Text=text; b.TextColor3=acc or C.Cyan
    b.TextSize=13; b.Font=Enum.Font.GothamBold; b.AutoButtonColor=false; b.BorderSizePixel=0
    b.TextScaled=false; b.RichText=true; b.TextStrokeTransparency=1
    Corner(b,8); Stroke(b,acc or C.Cyan,1,0.4)
    b.MouseEnter:Connect(function() Tw(b,{BackgroundTransparency=0.08}) end)
    b.MouseLeave:Connect(function() Tw(b,{BackgroundTransparency=C.GP}) end)
    return b
end
