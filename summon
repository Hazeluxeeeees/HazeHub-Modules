local function ReadPlayerPath(...)
    local val = nil
    pcall(function()
        local node = RS:WaitForChild("Player_Data",3):WaitForChild(LP.Name,3)
        for _, part in ipairs({...}) do node = node:WaitForChild(part,2) end
        val = tonumber(node.Value)
    end)
    return val
end

local function GetActiveAutoSells()
    local t = {}
    for _, rar in ipairs(RARITIES) do
        if autoSellState[rar] then t[rar] = true end
    end
    return t
end

-- Bypass: schließt den "Click anywhere"-Screen nach dem Summon
local function BypassClickScreen()
    task.spawn(function()
        for attempt = 1, 12 do
            task.wait(0.4)
            local closed = false
            -- Variante 1: PlayerGui nach Click/Continue Buttons scannen
            pcall(function()
                local pg = LP:WaitForChild("PlayerGui",2)
                for _, desc in ipairs(pg:GetDescendants()) do
                    if desc:IsA("TextButton") or desc:IsA("ImageButton") then
                        local n = desc.Name:lower()
                        if n:find("click") or n:find("continue") or n:find("anywhere") then
                            pcall(function() desc.Parent.Visible = false end)
                            closed = true
                        end
                    end
                    -- Frame-basierter Result-Screen
                    if desc:IsA("Frame") and desc.Visible then
                        local n = desc.Name:lower()
                        if n:find("result") or n:find("gacha") or n:find("reward") then
                            pcall(function()
                                local center = desc.AbsolutePosition + desc.AbsoluteSize * 0.5
                                game:GetService("VirtualInputManager"):SendMouseButtonEvent(
                                    math.floor(center.X), math.floor(center.Y), 0, true, game, 0)
                                task.wait(0.05)
                                game:GetService("VirtualInputManager"):SendMouseButtonEvent(
                                    math.floor(center.X), math.floor(center.Y), 0, false, game, 0)
                            end)
                            closed = true
                        end
                    end
                end
            end)
            if closed then break end
        end
    end)
end

