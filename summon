local function DoSummon(amount)
    if summonDebounce then
        sumStatusLbl.Text="⚠ Warte auf vorherigen Summon..."; sumStatusLbl.TextColor3=D.Orange
        return
    end
    summonDebounce = true
    local bannerDef = BANNERS[selectedBannerIdx]
    local amountStr = tostring(amount).."x"
    sumStatusLbl.Text=string.format("⏳ Summone %dx auf %s...", amount, bannerDef.display)
    sumStatusLbl.TextColor3=D.Yellow

    task.spawn(function()
        local ok, err = pcall(function()
            RS:WaitForChild("Remote",3)
              :WaitForChild("Server",3)
              :WaitForChild("Gambling",3)
              :WaitForChild("UnitsGacha",3)
              :FireServer(table.unpack({
                  [1] = amountStr,
                  [2] = bannerDef.remote,
                  [3] = GetActiveAutoSells(),
              }))
        end)

        if ok then
            sumStatusLbl.Text=string.format("✅ %dx auf '%s' gesummont!", amount, bannerDef.display)
            sumStatusLbl.TextColor3=D.GreenBright
            task.delay(1.5, function() pcall(RefreshPity) end)
        else
            sumStatusLbl.Text="❌ Fehler: "..tostring(err):sub(1,60)
            sumStatusLbl.TextColor3=D.Red
        end

        BypassClickScreen()

        task.wait(2.5)
        summonDebounce = false
        sumStatusLbl.Text="Bereit zum Summonen."
        sumStatusLbl.TextColor3=D.TextMid
    end)
end

