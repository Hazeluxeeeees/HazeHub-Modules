local function DoSummon(amt)
    if sumDbnc then sumSt.Text="⏳ Warte..."; sumSt.TextColor3=C.Yellow; return end
    sumDbnc=true
    local ban=BANNERS[selBan]
    sumSt.Text=string.format("⏳ Summone %dx auf '%s'...",amt,ban.disp); sumSt.TextColor3=C.Yellow
    task.spawn(function()
        local ok,err=pcall(function()
            RS:WaitForChild("Remote",3):WaitForChild("Server",3):WaitForChild("Gambling",3):WaitForChild("UnitsGacha",3):FireServer(tostring(amt).."x",ban.rem,GetAutoSells())
        end)
        if ok then sumSt.Text="✅ "..amt.."x auf '"..ban.disp.."' gesummont!"; sumSt.TextColor3=C.GreenB; task.delay(2,function() pcall(RefreshPity) end)
        else sumSt.Text="❌ "..tostring(err):sub(1,60); sumSt.TextColor3=C.Red end
        BypassClick()
        task.wait(2.5); sumDbnc=false; sumSt.Text="Bereit."; sumSt.TextColor3=C.Mid
    end)
end
